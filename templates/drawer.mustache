{{!
    @template aiplacement_airesourceguide/drawer

    Drawer shell for the AI Resource Guide.

    Context variables required for this template:
    * loading - boolean, whether to show the loading spinner.

    Example context (json):
    {
        "loading": true
    }
}}
<div class="airesguide-drawer-inner">
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <h5 class="mb-0">
            <i class="fa fa-book mr-2 text-primary"></i>
            {{#str}} pluginname, aiplacement_airesourceguide {{/str}}
        </h5>
        <button type="button" class="btn btn-sm btn-link airesguide-close" aria-label="{{#str}} close, core {{/str}}">
            <i class="fa fa-times fa-lg"></i>
        </button>
    </div>

    <p class="text-muted small mb-3">
        {{#str}} drawer_description, aiplacement_airesourceguide {{/str}}
    </p>

    <div class="airesguide-results">
        {{#loading}}
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" role="status">
                <span class="sr-only">{{#str}} loading, core {{/str}}</span>
            </div>
            <p class="text-muted">{{#str}} generating, aiplacement_airesourceguide {{/str}}</p>
        </div>
        {{/loading}}
    </div>

    <div class="mt-3 pt-2 border-top">
        <small class="text-muted">
            <i class="fa fa-info-circle mr-1"></i>
            {{#str}} ai_disclaimer, aiplacement_airesourceguide {{/str}}
        </small>
    </div>
</div>
